<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.dino.presentation.controllers.GameController"
            style="-fx-background-color: #1c1a22;">
    <top>
        <HBox spacing="18" alignment="CENTER_LEFT"
              style="-fx-background-color: #26232d; -fx-padding: 10 14; -fx-border-color: #4d4659; -fx-border-width: 0 0 2 0;">
            <Label text="THREADED"
                   style="-fx-text-fill: #e8dfcf; -fx-font-size: 22px; -fx-font-weight: bold; -fx-font-family: 'Monospaced';"/>
            <Label fx:id="timerLabel"
                   text="Tiempo: 0.0s"
                   style="-fx-text-fill: #e8dfcf; -fx-font-size: 14px; -fx-font-family: 'Monospaced';"/>
            <Label fx:id="levelLabel"
                   text="Nivel 1/N"
                   style="-fx-text-fill: #e8dfcf; -fx-font-size: 14px; -fx-font-family: 'Monospaced';"/>
            <Label fx:id="roomStatusLabel"
                   text="Llega a la meta evitando hazards"
                   style="-fx-text-fill: #d1a35b; -fx-font-size: 14px; -fx-font-family: 'Monospaced';"/>
            <Label fx:id="threadLabel"
                   text="Hilo maximo: --"
                   style="-fx-text-fill: #b8ad9a; -fx-font-size: 14px; -fx-font-family: 'Monospaced';"/>
            <Label fx:id="networkLabel"
                   text="UDP host autoritativo"
                   style="-fx-text-fill: #b8ad9a; -fx-font-size: 14px; -fx-font-family: 'Monospaced';"/>
        </HBox>
    </top>

    <center>
        <StackPane style="-fx-padding: 14;">
            <Canvas fx:id="arenaCanvas" width="960" height="640"/>
            <Label fx:id="feedbackLabel"
                   StackPane.alignment="TOP_CENTER"
                   visible="false"
                   style="-fx-text-fill: #e8dfcf; -fx-font-size: 18px; -fx-font-weight: bold; -fx-font-family: 'Monospaced';"/>
        </StackPane>
    </center>

    <right>
        <VBox spacing="12" prefWidth="250"
              style="-fx-background-color: #26232d; -fx-padding: 14; -fx-border-color: #4d4659; -fx-border-width: 0 0 0 2;">
            <Label text="Ranking en vivo"
                   style="-fx-text-fill: #e8dfcf; -fx-font-size: 15px; -fx-font-weight: bold; -fx-font-family: 'Monospaced';"/>
            <ListView fx:id="playersList" VBox.vgrow="ALWAYS"/>
            <Label text="Eventos"
                   style="-fx-text-fill: #e8dfcf; -fx-font-size: 15px; -fx-font-weight: bold; -fx-font-family: 'Monospaced';"/>
            <ListView fx:id="eventLog" VBox.vgrow="ALWAYS"/>
            <Label text="Controles: mueve el mouse para apuntar la direccion del personaje y click izquierdo para saltar. Los bloques, hazards y metas siguen una lectura de tile clara en toda la campana."
                   wrapText="true"
                   style="-fx-text-fill: #b8ad9a; -fx-font-size: 12px; -fx-font-family: 'Monospaced';"/>
        </VBox>
    </right>

    <padding>
        <Insets top="0" right="0" bottom="0" left="0"/>
    </padding>
</BorderPane>
