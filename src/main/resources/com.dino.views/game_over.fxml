<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.dino.presentation.controllers.GameOverController"
      alignment="CENTER"
      spacing="22"
      style="-fx-background-color: linear-gradient(to bottom, #0d1524, #152033 42%, #1a2437 100%); -fx-padding: 48;">

    <VBox alignment="CENTER" spacing="8">
        <Label text="THREADED"
               style="-fx-font-size: 48px; -fx-font-weight: bold; -fx-text-fill: #eef4fb; -fx-font-family: 'Monospaced';"/>
        <Label text="campana completada"
               style="-fx-font-size: 12px; -fx-text-fill: #8dd4ff; -fx-font-family: 'Monospaced'; -fx-background-color: rgba(16,39,60,0.92); -fx-background-radius: 999; -fx-padding: 5 14 5 14;"/>
    </VBox>

    <VBox spacing="10" maxWidth="680"
          style="-fx-background-color: rgba(15,22,33,0.95); -fx-background-radius: 26; -fx-border-radius: 26; -fx-border-color: #37506a; -fx-border-width: 2; -fx-padding: 26;">
        <Label text="Resultado de la partida"
               style="-fx-font-size: 18px; -fx-text-fill: #8fc9ff; -fx-font-family: 'Monospaced';"/>

        <Label fx:id="winnerLabel"
               text="Ganador: -"
               style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #97e7ab; -fx-font-family: 'Monospaced';"/>

        <Label fx:id="totalTimeLabel"
               text="Tiempo total: 0.0s"
               style="-fx-font-size: 14px; -fx-text-fill: #b9c6d7; -fx-font-family: 'Monospaced';"/>

        <VBox spacing="8" style="-fx-padding: 12 0 0 0;">
            <Label text="Resultado final"
                   style="-fx-text-fill: #eef4fb; -fx-font-size: 15px; -fx-font-weight: bold; -fx-font-family: 'Monospaced';"/>
            <TableView fx:id="resultsTable" prefHeight="280"
                       style="-fx-background-color: #10161f; -fx-border-color: #2d3948; -fx-border-radius: 16; -fx-background-radius: 16; -fx-font-family: 'Monospaced';">
                <columns>
                    <TableColumn fx:id="posColumn" text="Posicion" prefWidth="90"/>
                    <TableColumn fx:id="nameColumn" text="Jugador" prefWidth="250"/>
                    <TableColumn fx:id="scoreColumn" text="Puntaje" prefWidth="170"/>
                </columns>
            </TableView>
        </VBox>
    </VBox>

    <Button text="VOLVER AL MENU"
            onAction="#onVolverAlMenu"
            style="-fx-background-color: linear-gradient(to bottom, #8fe0ff, #69c9f0); -fx-text-fill: #0f1824; -fx-font-weight: bold; -fx-font-size: 15px; -fx-font-family: 'Monospaced'; -fx-padding: 12 34; -fx-background-radius: 14;"/>
</VBox>
